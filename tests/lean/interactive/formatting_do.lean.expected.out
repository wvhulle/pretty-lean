  "newText":
  "def greet (name : String) : IO Unit := do\n  let msg := s! \"Hello, {name}!\"\n  IO.println msg\n\ndef count : IO Unit := do\n  let mut s := 0\n  for i in [0, 1, 2, 3]do\n    s := s + i\n  IO.println s! \"{s}\"\n--^ formatting\n"}]
